#!/usr/bin/with-contenv bash

PLUGIN_ROOT="/config/Library/Application Support/Plex Media Server/Plug-ins"
SCANNER_ROOT="/config/Library/Application Support/Plex Media Server/Scanners"
PLEX_DB_ROOT="/config/Library/Application Support/Plex Media Server/Plug-in Support/Databases"
PLEX_PREFERENCES="/config/Library/Application Support/Plex Media Server/Preferences.xml"

PTC_ROOT="/config/Library/Application Support/Plex Media Server/Cache/PhotoTranscoder"

PLEX_SQLITE="/usr/lib/plexmediaserver/Plex SQLite"
PLEX_SCANNER="/usr/lib/plexmediaserver/Plex Media Scanner"

PLEX_USER=$(if getent passwd plex > /dev/null; then echo "plex"; else echo "abc"; fi)
PLEX_DB_FILE="${PLEX_DB_ROOT}/com.plexapp.plugins.library.db"

if [ -f "${PLEX_PREFERENCES}" ]; then
    PLEX_TOKEN=$(sed -n 's/.*PlexOnlineToken="//p' "${PLEX_PREFERENCES}" | sed "s/\".*//")
fi

git_owner_repo_from_url() {
  # stdin or $1
  local url="${1:-$(cat)}"
  url="${url%.git}"

  # scp-style: git@host:owner/repo
  if [[ "$url" =~ ^[^@]+@[^:]+:(.+)$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return 0
  fi

  # scheme-style: https://host/owner/repo , ssh://git@host/owner/repo
  url="${url#*://}"      # remove scheme
  url="${url#*@}"        # remove user@
  url="${url#*/}"        # remove host/
  echo "$url"
}

git_safe() {
  local path="$1"
  shift
  git -c safe.directory="${path}" -C "${path}" "$@"
}

git_pull() {
  # return codes
  # 0 = updated or already up-to-date
  # 1 = reinstall recommended
  # 2 = reinstall won't help
  # 
  # depends on is_git_dir() git_safe() git_owner_repo_from_url()

  local repo="$1"
  indent() { sed 's/^/    /'; }

  [ -n "$repo" ] || return 2
  [ -d "$repo" ] || return 1

  # not a git repo -> reinstall recommended
  is_git_dir "$repo" || return 1

  local git_dir url owner_repo branch before after out rc

  # cleanup stale lock (best-effort)
  git_dir="$(git_safe "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || return 1
  rm -f "$git_dir/index.lock" 2>/dev/null

  # missing origin -> reinstall recommended
  url="$(git_safe "$repo" config --get remote.origin.url 2>/dev/null)" || return 1
  branch="$(git_safe "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)" || return 1
  [ "$branch" = "HEAD" ] && { echo "detached HEAD (no branch)" | indent; return 2; }

  owner_repo="$(git_owner_repo_from_url "$url" 2>/dev/null || echo "$url" | cut -d/ -f4-)"
  before="$(git_safe "$repo" rev-parse HEAD 2>/dev/null)"

  echo "*** checking for updates: $owner_repo"
  out="$(git_safe "$repo" fetch --prune origin 2>&1)"; rc=$?
  if [ $rc -ne 0 ]; then
    echo "$out" | indent
    grep -Eq \
      'not a git repository|bad object|loose object|index file corrupt|object file.*is empty|corrupt pack' \
      <<<"$out" && return 1
    return 2
  fi

  # remote branch missing -> reinstall won't help (can't preserve branch policy)
  git_safe "$repo" show-ref --verify --quiet "refs/remotes/origin/$branch" || {
    echo "missing remote branch: origin/$branch" | indent
    return 2
  }

  out="$(git_safe "$repo" reset --quiet --hard "origin/$branch" 2>&1)"; rc=$?
  if [ $rc -ne 0 ]; then
    echo "$out" | indent
    return 1
  fi

  after="$(git_safe "$repo" rev-parse HEAD 2>/dev/null)"
  if [ "$before" != "$after" ]; then
    echo "updated: ($branch) ${before:0:7} -> ${after:0:7}" | indent
  fi

  return 0
}

is_git_dir() {
    if [ "$(git_safe "$1" rev-parse --is-inside-work-tree 2>/dev/null)" = "true" ]; then return 0; fi
    return 1
}

is_same_repo() {
  if [ $# -lt 2 ]; then return 1; fi
  local repo_path="$1"
  local target_repo="$2" # owner/repo
  local target_branch="${3:-}"
  is_git_dir "$repo_path" || return 1

  local url current_repo
  url=$(git_safe "$repo_path" config --get remote.origin.url 2>/dev/null) || return 1
  current_repo=$(git_owner_repo_from_url "$url") || return 1
  [ -n "$current_repo" ] && [ "$current_repo" = "$target_repo" ] || return 1

  local current_branch
  current_branch=$(git_safe "$repo_path" rev-parse --abbrev-ref HEAD 2>/dev/null) || return 1
  [ "$current_branch" != "HEAD" ] || return 1

  if [ -z "$target_branch" ]; then
    local default_branch
    default_branch=$(git_safe "$repo_path" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null) \
      && target_branch="${default_branch#origin/}" || return 1
  fi
  [ "$current_branch" = "$target_branch" ] || return 1
  return 0
}

install_bundle() {
    local bundle_spec="$1" # repo/owner[@branch]
    [ -n "${bundle_spec}" ] || return 1

    local bundle_repo bundle_ref git_repo bundle_root mvto rc
    bundle_repo="${bundle_spec%@*}" # repo/owner
    [[ "${bundle_spec}" == *"@"* ]] && bundle_ref="${bundle_spec##*@}"

    git_repo="${bundle_repo##*/}"
    bundle_root="${PLUGIN_ROOT}/${git_repo}"

    do_install() {
        local repo_url="https://github.com/${bundle_repo}"

        if [ -n "${bundle_ref}" ]; then
            git -C "${PLUGIN_ROOT}" clone --quiet --depth 1 \
                --branch "${bundle_ref}" \
                "${repo_url}" >/dev/null
        else
            git -C "${PLUGIN_ROOT}" clone --quiet --depth 1 \
                "${repo_url}" >/dev/null
        fi
    }

    reinstall() {
        rm -rf "${bundle_root}" && do_install
    }

    if [ -f "${bundle_root}/.noupdate" ]; then
      echo "*** found .noupdate file! ignoring $bundle_spec"
      return 0
    fi

    if [ ! -d "${bundle_root}" ]; then
        echo "*** installing ${bundle_spec}"
        do_install || return 1
    elif ! is_git_dir "${bundle_root}"; then
        echo "*** re-installing ${bundle_spec} as not a git repo"
        reinstall || return 1
    elif ! is_same_repo "${bundle_root}" "${bundle_repo}" "${bundle_ref}"; then
        echo "*** re-installing ${bundle_spec} due to repo/branch mismatch"
        reinstall || return 1
    else
        git_pull "${bundle_root}"
        rc=$?
        case $rc in
            0) ;;
            1)
                echo "    re-installing ${bundle_spec}"
                reinstall
                ;;
            2) ;;
        esac
    fi

    if [[ "${bundle_repo}" == *SjvaAgent.bundle ]]; then
        # install and update dummy agents
        for BUN in "${bundle_root}"/*/*.bundle; do
            [ -d "${BUN}" ] || continue
            rm -rf "${PLUGIN_ROOT:?}/$(basename "$BUN")"
            mv "$BUN" "${PLUGIN_ROOT}"
        done

        # install and update scanners
        for SCN in "${bundle_root}"/Scanners/*; do
            [ -d "$SCN" ] || continue
            mvto="${SCANNER_ROOT}/$(basename "$SCN")"
            mkdir -p "$mvto"
            mv "$SCN"/* "${mvto}/"
        done
    fi
}

fix_ownership() {
  find "$@" \! \( -uid "$(id -u "$PLEX_USER")" -gid "$(id -g "$PLEX_USER")" \) -print0 | \
    xargs -0 --no-run-if-empty chown -h "$PLEX_USER":"$PLEX_USER"
}
